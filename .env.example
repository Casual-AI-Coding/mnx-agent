# =============================================================================
# MiniMax Agent Environment Configuration Template
# =============================================================================
# ⚠️  CRITICAL: After deployment, you MUST rotate all secrets in .env
#    DO NOT use the placeholder values in production!
#
# For generating secure secrets, use:
#   - JWT_SECRET: openssl rand -base64 32
#   - DB_PASSWORD: openssl rand -base64 24
#   - API_KEY: Get from MiniMax dashboard at https://platform.minimaxi.com
# =============================================================================

# MiniMax API Configuration
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_REGION=domestic
MINIMAX_API_HOST_CN=https://api.minimaxi.com
MINIMAX_API_HOST_INTL=https://api.minimax.io

# Server Configuration
PORT=4511
NODE_ENV=development

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=mnx_agent_server
# Generate: openssl rand -base64 24
DB_PASSWORD=your_secure_database_password_here
DB_NAME=mnx_agent
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# JWT Authentication
# Generate: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here

# Media Token Secret (for temporary file access)
# Generate: openssl rand -base64 32
MEDIA_TOKEN_SECRET=your_secure_media_token_secret_here

# Rate Limit Configuration
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100

# Test Accounts (for development only - DO NOT use in production)
TEST_SUPER_USER=TestSuper
TEST_SUPER_PASS=your_test_password_here
TEST_ADMIN_USER=TestAdmin
TEST_ADMIN_PASS=your_test_password_here
TEST_PRO_USER=TestPro
TEST_PRO_PASS=your_test_password_here
TEST_USER_USER=TestUser
TEST_USER_PASS=your_test_password_here
