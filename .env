# MiniMax API Configuration
# Copy this file to .env.local and fill in your real API key
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_REGION=domestic
MINIMAX_API_HOST_CN=https://api.minimaxi.com
MINIMAX_API_HOST_INTL=https://api.minimax.io

# Server Configuration
PORT=4511
NODE_ENV=development

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=mnx_agent_server
DB_PASSWORD=change_me
DB_NAME=mnx_agent
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# JWT Authentication
JWT_SECRET=change_me_to_a_random_secret
MEDIA_TOKEN_SECRET=change_me_to_another_random_secret

# Rate Limit Configuration
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100

# Test Accounts
TEST_SUPER_USER=TestSuper
TEST_SUPER_PASS=your_test_password
TEST_ADMIN_USER=TestAdmin
TEST_ADMIN_PASS=your_test_password
TEST_PRO_USER=TestPro
TEST_PRO_PASS=your_test_password
TEST_USER_USER=TestUser
TEST_USER_PASS=your_test_password
